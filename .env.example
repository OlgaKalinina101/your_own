# ── LLM Providers ────────────────────────────────────────────────────────────
# OpenRouter key is now stored server-side in data/settings.json.
# Configure it via the Settings page in the app.
# (Legacy: set here only if running backend standalone without the app.)
OPENROUTER_API_KEY=sk-or-CHANGE_ME

# ── Auth ─────────────────────────────────────────────────────────────────────
# Auto-generated on first run → data/auth_token.txt
# Copy this token into the desktop/mobile app to connect.
# AUTH_TOKEN is displayed in the backend console on startup.

# ── Database ──────────────────────────────────────────────────────────────────
# Default (set automatically by scripts/setup.js — no action needed for local dev):
DATABASE_URL=postgresql+asyncpg://postgres:1234@localhost:5432/your_own
# For Supabase / managed Postgres, replace the line above:
# DATABASE_URL=postgresql+asyncpg://postgres:<password>@db.<ref>.supabase.co:5432/postgres

# ── ChromaDB ──────────────────────────────────────────────────────────────────
VECTOR_STORE_DIR=infrastructure/vector_store
CHROMA_COLLECTION_NAME=key_info

# ── Embeddings ────────────────────────────────────────────────────────────────
EMBEDDING_MODEL_NAME=paraphrase-multilingual-MiniLM-L12-v2

# ── Network / Remote Access ──────────────────────────────────────────────────
# Backend bind host (default: 0.0.0.0 for LAN/tunnel access)
# BACKEND_HOST=0.0.0.0

# Internal backend URL used by the Next.js API proxy (server-side only).
# No need to change unless the backend runs on a different machine.
# BACKEND_INTERNAL_URL=http://127.0.0.1:8000

# Public backend URL for direct client connections (Electron / local dev).
# When accessing via ngrok, the Next.js proxy handles routing automatically.
# NEXT_PUBLIC_BACKEND_URL=http://localhost:8000

# Extra allowed dev origins (comma-separated), appended to the default
# *.ngrok-free.dev and *.ngrok.io wildcards in next.config.mjs.
# ALLOWED_DEV_ORIGINS=my-tunnel.example.com,another.dev
