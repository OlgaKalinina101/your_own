# ── LLM Providers ────────────────────────────────────────────────────────────
# OpenRouter key is stored in the system keychain by the Electron app.
# Set here only if running the backend standalone (without Electron).
OPENROUTER_API_KEY=sk-or-CHANGE_ME

# ── External Services ─────────────────────────────────────────────────────────
OPENWEATHER_API_KEY=
GOOGLE_MAPS_API_KEY=
PUSHY_SECRET_KEY=

# ── Core Settings ─────────────────────────────────────────────────────────────
CREATOR_ACCOUNT_ID=my_user
TIMEZONE=Europe/Moscow

# ── Database ──────────────────────────────────────────────────────────────────
# Default (set automatically by scripts/setup.js — no action needed for local dev):
DATABASE_URL=postgresql+asyncpg://postgres:1234@localhost:5432/your_own
# For Supabase / managed Postgres, replace the line above:
# DATABASE_URL=postgresql+asyncpg://postgres:<password>@db.<ref>.supabase.co:5432/postgres

# ── Storage Paths ─────────────────────────────────────────────────────────────
SESSION_CONTEXT_DIR=infrastructure/context_store/sessions
VECTOR_STORE_DIR=infrastructure/vector_store
DEMO_KEYS_DIR=infrastructure/database/demo_keys.json
CHROMA_COLLECTION_NAME=key_info

# ── Persona & Prompts ─────────────────────────────────────────────────────────
SYSTEM_PROMPT_PATH=core/persona/prompts/system.yaml
CONTEXT_PROMPT_PATH=core/dialog/templates/context.yaml

# ── Model Settings ────────────────────────────────────────────────────────────
VICTOR_CORE_ROOT=.
MODEL_SETTINGS=infrastructure/llm/model_settings.yaml
EMBEDDING_MODEL_NAME=paraphrase-multilingual-MiniLM-L12-v2

# ── Autonomy ──────────────────────────────────────────────────────────────────
AUTONOMY_DATA_DIR=data/autonomy
REFLECTION_COOLDOWN_HOURS=4
REFLECTION_MIN_INTERVAL_HOURS=12
WORKBENCH_RETENTION_HOURS=48
VICTOR_NOTES_COLLECTION=victor_notes
